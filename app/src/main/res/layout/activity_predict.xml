<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f0f4f8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1a3a5c"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🦷 New Prediction"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Back"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2d7dd2"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient Information"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1a3a5c"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient Name"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etPatientName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Enter patient name"
                        android:padding="12dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etAge"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Enter age"
                        android:inputType="number"
                        android:padding="12dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gender"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerGender"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medical History"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1a3a5c"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Diabetes"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerDiabetes"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hypertension"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerHypertension"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smoking"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerSmoking"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trauma Details"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1a3a5c"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fracture Type"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerFractureType"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Number of Fractures"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etNumFractures"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g. 2"
                        android:inputType="number"
                        android:padding="12dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time to Surgery (hours)"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etTimeToSurgery"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g. 12"
                        android:inputType="number"
                        android:padding="12dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Surgery Duration (minutes)"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etSurgeryDuration"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g. 120"
                        android:inputType="number"
                        android:padding="12dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="12dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- CT Scan Upload Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CT Scan Upload (Optional)"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1a3a5c"
                        android:layout_marginBottom="12dp"/>

                    <Button
                        android:id="@+id/btnSelectCT"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Select CT Scan Image"
                        android:textColor="#2d7dd2"
                        android:backgroundTint="#f0f4f8"/>

                    <TextView
                        android:id="@+id/tvCTFileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No file selected"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnPredict"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Get Prediction"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#28a745"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>