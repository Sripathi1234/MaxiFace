<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f0f4f8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1a3a5c"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Prediction Result"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
        <Button
            android:id="@+id/btnDashboard"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Dashboard"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2d7dd2"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvPatientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient: "
                android:textSize="15sp"
                android:textColor="#555555"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"/>

            <!-- Overall Risk Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/riskCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="28dp">
                    <TextView
                        android:id="@+id/tvRiskIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HIGH RISK"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Risk Level"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:alpha="0.8"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:id="@+id/tvRiskLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="High"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:id="@+id/tvRiskPercentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="96% risk"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:alpha="0.9"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Detailed Risk Breakdown Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detailed Risk Breakdown"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1a3a5c"
                        android:layout_marginBottom="16dp"/>

                    <!-- Row 1: Infection + Nerve -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- Infection Risk -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="10dp"
                            app:cardBackgroundColor="#F8F9FA">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="6dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Infection Risk"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:textColor="#333333"/>
                                    <TextView
                                        android:id="@+id/tvInfectionLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Low"
                                        android:textSize="10sp"
                                        android:textColor="#27ae60"
                                        android:paddingHorizontal="6dp"
                                        android:paddingVertical="2dp"/>
                                </LinearLayout>
                                <ProgressBar
                                    android:id="@+id/progressInfection"
                                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:max="100"
                                    android:layout_marginBottom="4dp"/>
                                <TextView
                                    android:id="@+id/tvInfectionPct"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="16%"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"
                                    android:gravity="end"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Nerve Damage Risk -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="10dp"
                            app:cardBackgroundColor="#F8F9FA">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="6dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Nerve Damage"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:textColor="#333333"/>
                                    <TextView
                                        android:id="@+id/tvNerveLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Low"
                                        android:textSize="10sp"
                                        android:textColor="#27ae60"
                                        android:paddingHorizontal="6dp"
                                        android:paddingVertical="2dp"/>
                                </LinearLayout>
                                <ProgressBar
                                    android:id="@+id/progressNerve"
                                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:max="100"
                                    android:layout_marginBottom="4dp"/>
                                <TextView
                                    android:id="@+id/tvNervePct"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="18%"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"
                                    android:gravity="end"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <!-- Row 2: Malocclusion + Delayed -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Malocclusion Risk -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="10dp"
                            app:cardBackgroundColor="#F8F9FA">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="6dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Malocclusion"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:textColor="#333333"/>
                                    <TextView
                                        android:id="@+id/tvMalocclusionLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="High"
                                        android:textSize="10sp"
                                        android:textColor="#e74c3c"
                                        android:paddingHorizontal="6dp"
                                        android:paddingVertical="2dp"/>
                                </LinearLayout>
                                <ProgressBar
                                    android:id="@+id/progressMalocclusion"
                                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:max="100"
                                    android:layout_marginBottom="4dp"/>
                                <TextView
                                    android:id="@+id/tvMalocclusionPct"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="96%"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"
                                    android:gravity="end"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Delayed Healing Risk -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="10dp"
                            app:cardBackgroundColor="#F8F9FA">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="6dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Delayed Healing"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:textColor="#333333"/>
                                    <TextView
                                        android:id="@+id/tvDelayedLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Low"
                                        android:textSize="10sp"
                                        android:textColor="#27ae60"
                                        android:paddingHorizontal="6dp"
                                        android:paddingVertical="2dp"/>
                                </LinearLayout>
                                <ProgressBar
                                    android:id="@+id/progressDelayed"
                                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:max="100"
                                    android:layout_marginBottom="4dp"/>
                                <TextView
                                    android:id="@+id/tvDelayedPct"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="22%"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"
                                    android:gravity="end"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Complication + Recommendation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Predicted Complication"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1a3a5c"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/tvComplication"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Delayed Healing"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recommendation"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1a3a5c"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/tvRecommendation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Immediate attention required."
                            android:textSize="11sp"
                            android:textColor="#555555"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Buttons -->
            <Button
                android:id="@+id/btnNewPrediction"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="New Prediction"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1a3a5c"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>